---
// src/components/Header.astro
---

<header class="header">
    <div class="header__inner">
        <div class="logo">
            <a href="/">
                <img src="/images/logo-goon-video.svg" alt="GOONVIDEO logo" />
            </a>
        </div>
        
        <button class="burger-menu" aria-label="Ouvrir le menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <nav class="nav">
            <a href="/">Home</a>
            <a href="/portfolio">Portfolio</a>
            <a href="/tarifs">Tarifs</a>
            <a href="/contact">Contact</a>
            <a href="/devis" class="btn-yellow mobile-only-btn">DEMANDER UN DEVIS</a>
        </nav>
        
        <a href="/devis" class="btn-yellow desktop-only-btn">DEMANDER UN DEVIS</a>
    </div>
</header>

<script>
    // Petit script pour ouvrir/fermer le menu sur mobile
    const burger = document.querySelector('.burger-menu');
    const nav = document.querySelector('.nav');

    burger?.addEventListener('click', () => {
        burger.classList.toggle('active');
        nav?.classList.toggle('active');
    });
</script>

<style lang="scss">
    @use "../styles/variables" as vars;

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 100; 
        //background-color: rgba(3, 15, 37, 0.8);
		background-color: rgba(3, 15, 37, 0.95);
		border-bottom: 1px solid rgba(vars.$gold, 0.3);
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(10px);

        &__inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
			padding: 0.6rem 2rem;
            width: 100%;
            max-width: 90rem;
            margin: 0 auto;
        }
    }

    .logo img { height: 70px; }

    .nav { display: flex; gap: 2rem; align-items: center; }
    .nav a { font-weight: 600; text-transform: uppercase; font-size: 0.9rem; }

    .mobile-only-btn { display: none; }
    .burger-menu { display: none; }

    /* --- RESPONSIVE MOBILE --- */
    @media (max-width: 900px) {
        .header { padding: 0.6rem 1rem; }
        .logo img { height: 50px; }
        .desktop-only-btn { display: none; }
        .mobile-only-btn { display: block; margin-top: 1rem; text-align: center; }
        
        .burger-menu {
            display: flex;
            flex-direction: column;
            gap: 6px;
            background: none;
            border: none;
            cursor: pointer;
            z-index: 101;
            
            span {
                display: block;
                width: 30px;
                height: 3px;
                background-color: white;
                transition: 0.3s ease;
            }

            &.active span:nth-child(1) { transform: translateY(9px) rotate(45deg); }
            &.active span:nth-child(2) { opacity: 0; }
            &.active span:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }
        }

        .nav {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            height: 100vh;
            background-color: vars.$dark-blue;
            flex-direction: column;
            justify-content: center;
            transition: 0.3s ease;
            box-shadow: -5px 0 15px rgba(0,0,0,0.5);

            &.active { right: 0; }
        }
    }
</style>