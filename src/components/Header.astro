---
// 1. On récupère l'URL complète
const pathname = new URL(Astro.request.url).pathname;

// 2. On nettoie l'URL (on enlève le slash final s'il existe, sauf pour la home)
// Ex: "/portfolio/" devient "/portfolio"
const currentPath = pathname === "/" ? "" : pathname.replace(/\/$/, "");
---

<header class="header">
    <div class="header__inner">
        <div class="logo">
            <a href="/">
                <img src="/images/logo-goon-video.svg" alt="GOONVIDEO logo" />
            </a>
        </div>
        
        <button class="burger-menu" aria-label="Ouvrir le menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <nav class="nav">
            <a href="/" class={currentPath === "" ? "active" : ""}>Home</a>
            <a href="/portfolio" class={currentPath === "/portfolio" ? "active" : ""}>Portfolio</a>
            <a href="/tarifs" class={currentPath === "/tarifs" ? "active" : ""}>Tarifs</a>
            <a href="/contact" class={currentPath === "/contact" ? "active" : ""}>Contact</a>
            <a href="/devis" class="btn-yellow mobile-only-btn">DEMANDER UN DEVIS</a>
        </nav>
        
        <a href="/devis" class="btn-yellow desktop-only-btn">DEMANDER UN DEVIS</a>
    </div>
</header>

<script>
    // Petit script pour ouvrir/fermer le menu sur mobile
    const burger = document.querySelector('.burger-menu');
    const nav = document.querySelector('.nav');

    burger?.addEventListener('click', () => {
        burger.classList.toggle('active');
        nav?.classList.toggle('active');
    });
</script>

<style lang="scss">
    @use "../styles/variables" as vars;

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 100; 
        //background-color: rgba(3, 15, 37, 0.8);
        background-color: rgba(3, 15, 37, 0.95);
        border-bottom: 1px solid rgba(vars.$gold, 0.3);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(10px);

        &__inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.6rem 2rem;
            width: 100%;
            max-width: 90rem;
            margin: 0 auto;
        }
    }

    .logo img { height: 70px; }

    .nav { 
        display: flex; 
        gap: 2.5rem; 
        align-items: center; 

        a { 
            position: relative;
            font-weight: 600; 
            text-transform: uppercase; 
            font-size: 0.9rem; 
            color: white;
            text-decoration: none;
            transition: color 0.3s ease;

            // L'effet de ligne magique
            &::after {
                content: '';
                position: absolute;
                width: 0;
                height: 2px;
                bottom: -5px;
                left: 50%;
                background-color: vars.$gold; // Ou ta couleur d'accentuation
                transition: all 0.3s ease-in-out;
                transform: translateX(-50%);
            }

            &:hover {
                &::after {
                    width: 100%;
                }
            }

            // Style pour la page active
            &.active {
                color: vars.$gold;
                &::after {
                    width: 100%;
                }
            }
            
            // On désactive l'effet de ligne sur le bouton de devis
            &.btn-yellow::after { display: none; }
        }
    }

    .mobile-only-btn { display: none; }
    .burger-menu { display: none; }

    /* --- RESPONSIVE MOBILE --- */
    @media (max-width: 900px) {
        .header { padding: 0.6rem 1rem; }
        .logo img { height: 50px; }
        .desktop-only-btn { display: none; }
        .mobile-only-btn { display: block; margin-top: 1rem; text-align: center; }
        
        .burger-menu {
            display: flex;
            flex-direction: column;
            gap: 6px;
            background: none;
            border: none;
            cursor: pointer;
            z-index: 101;
            
            span {
                display: block;
                width: 30px;
                height: 3px;
                background-color: white;
                transition: 0.3s ease;
            }

            &.active span:nth-child(1) { transform: translateY(9px) rotate(45deg); }
            &.active span:nth-child(2) { opacity: 0; }
            &.active span:nth-child(3) { transform: translateY(-9px) rotate(-45deg); }
        }

        .nav {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            height: 100vh;
            background-color: vars.$dark-blue;
            flex-direction: column;
            justify-content: center;
            transition: 0.3s ease;
            box-shadow: -5px 0 15px rgba(0,0,0,0.5);

            &.active { right: 0; }
        }
    }
</style>