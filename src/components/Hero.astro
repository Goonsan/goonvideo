---
// src/components/Hero.astro
---

<section class="hero">
    <video autoplay loop muted playsinline class="hero-video" aria-hidden="true">
        <source src="/videos/showreel.mp4" type="video/mp4" />
    </video>
</section>

<section class="block-hero-content">
    <div class="hero-content">
        <div class="hero-scroll-container">
            <div class="hero-scroll" aria-hidden="true">
                <svg id="mouse" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mouse-icon lucide-mouse"><rect x="5" y="2" width="14" height="20" rx="7"/><path d="M12 6v4"/></svg>
                <svg id="arrowmouse" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-move-down-icon lucide-move-down"><path d="M8 18L12 22L16 18"/><path d="M12 2V22"/></svg>
            </div>
        </div>

        <h1 class="hero-title">DONNEZ VIE À VOS PROJETS, DE L'ÉMOTION À L'IMAGE.</h1>
        
        <div class="hero-description">
            <h2>Vidéaste - captation & montage</h2>
            <p>Olivier Gonnet — Vidéaste spécialisé en captation et montage pour vos mariages, clips musicaux et projets d’entreprise.</p>
        </div>

        <div class="hero-buttons">
            <a href="/portfolio" class="btn-yellow">DÉCOUVRIR MON UNIVERS</a>
            <a href="/devis" class="btn-outlined">DEMANDER UN DEVIS</a>
        </div>
    </div>
</section>

<style lang="scss">
    @use "../styles/variables" as vars;

    .hero {
        position: relative;
        width: 100%;
        height: 80vh; 
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        text-align: center;
        overflow: hidden;
        margin-top: 6rem;
        background-color: black; // Fond de secours pendant le chargement vidéo
    }

    .hero-video {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100%;
        height: 100%;
        transform: translate(-50%, -50%);
        z-index: 0;
        object-fit: cover;
    }

    .block-hero-content {
        position: relative;
        z-index: 1;
        background-color: vars.$dark-blue; // Utilisation de ta variable
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 850px;
        padding: 2rem 3rem 3rem;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
        border-radius: 1.6rem;
        background-color: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
        text-align: center;
        margin: 0 auto;
        top: -100px;
		box-sizing: border-box;
        border: solid 1px  vars.$gold;
        box-shadow: 0 2px 20px #000;
    }

    .hero-title {
        font-size: clamp(1.8rem, 5vw, 3.2rem); // Taille fluide
        font-weight: 800;
        line-height: 1.1;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: white;
    }

    .hero-description {
        h2 { 
            font-size: 1.5rem; 
            margin-bottom: 1rem; 
            color: vars.$gold; 
            text-transform: uppercase;
        }
        p { 
            font-size: 1.1rem; 
            max-width: 650px; 
            margin: 0 auto 2.5rem; 
            line-height: 1.6;
            opacity: 0.9;
        }
    }

    .hero-buttons { 
        display: flex; 
        gap: 1.5rem; 
        justify-content: center; 
        align-items: center;
    }

    .btn-yellow {
        background-color: vars.$gold;
        color: vars.$dark-blue;
        padding: 1rem 2rem;
        border-radius: 4px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
        &:hover { transform: translateY(-3px); filter: brightness(1.1); }
    }

    .btn-outlined {
        border: 2px solid white;
        color: white;
        padding: 0.9rem 2rem;
        border-radius: 4px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
        &:hover { background: white; color: black; }
    }

    /* Animation Mouse */
    .hero-scroll-container {
        position: absolute;
        top: -11px;
        left: 0;
        right: 0;
    }

    .hero-scroll {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000;

        &:before {
            content: "";
            border: solid 1px  vars.$gold;
            width: 3.4rem;
            height: 3.4rem;
            border-radius: 100%;
            position: absolute;
            background: vars.$gold;
            z-index: -1;
        }
    }

    svg#mouse {
        width: 2rem;
        height: 2rem;
        position: relative;
        left: 4px;
    }

    svg#arrowmouse {
        animation: bounce 2s infinite;
        position: relative;
        left: -4px;
    }

    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
        40% {transform: translateY(-10px);}
        60% {transform: translateY(-5px);}
    }

    /* --- RESPONSIVE MOBILE --- */
    @media (max-width: 768px) {
        .hero {
            height: 50vh; 
            margin-top: 4rem; // Correspond au header mobile
        }

        .hero-content {
            width: 92%;
            padding: 2.5rem 1.5rem;
            top: -50px; // Moins de remontée pour éviter de cacher la vidéo
            border-radius: 1rem;
        }

        .hero-title {
            font-size: 1.6rem;
            margin-bottom: 1rem;
        }

        .hero-description {
            h2 { font-size: 1.2rem; }
            p { font-size: 0.95rem; margin-bottom: 2rem; }
        }

        .hero-buttons {
            flex-direction: column; 
            gap: 1rem;
            
            a {display: block; text-align: center; }
        }

        .hero-scroll { display: none; } 
    }
</style>