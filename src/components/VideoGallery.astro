---
const videos = [
  { id: 'fXsKkRrIpZE', title: 'Mariage - Film Cinématographique', category: 'Mariage' },  
  { id: 'XIxziMQwV5Y', title: 'Mariage - Film Cinématographique', category: 'Mariage' },
  { id: 'NRXY9s8mrwg', title: 'Clip Musical - Artiste Indépendant', category: 'Musique' },
  { id: 'XuErLn2O0tA', title: 'Qui suis-je ? Storytelling & Vision', category: 'Portrait' },
  { id: 'iTCQW5TMQP4', title: 'Prestation Entreprise - Bien-être & Massage', category: 'Business' },
  { id: '1EEWf-xUXPg', title: "Sport - Au Cœur de l'Action", category: 'Sport' },
];

const categories = ['Tous', ...new Set(videos.map(v => v.category))];
---

<div class="portfolio-section">
    <div class="filter-container">
        {categories.map(cat => (
            <button class="filter-btn" data-category={cat === 'Tous' ? 'all' : cat}>
                {cat}
            </button>
        ))}
    </div>

    <div class="video-grid">
        {videos.map((video) => (
            <div class="video-card" data-category={video.category}>
                <div class="thumbnail-wrapper" data-video-id={video.id}>
                    <img 
                        src={`https://img.youtube.com/vi/${video.id}/hqdefault.jpg`} 
                        alt={video.title}
                        loading="lazy"
                    />
                    <div class="play-overlay">
                        <span class="play-text">Lire la vidéo</span>
                    </div>
                    <div class="category-badge">{video.category}</div>
                </div>
                <h3>{video.title}</h3>
            </div>
        ))}
    </div>
</div>

<script>
    // Filtrage
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.video-card');

    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = btn.getAttribute('data-category');
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            cards.forEach(card => {
                if (filter === 'all' || card.getAttribute('data-category') === filter) {
                    (card as HTMLElement).style.display = 'block';
                } else {
                    (card as HTMLElement).style.display = 'none';
                }
            });
        });
    });

    // Injection de l'iframe avec correction de taille
    const wrappers = document.querySelectorAll('.thumbnail-wrapper');
    wrappers.forEach(wrapper => {
        wrapper.addEventListener('click', () => {
            const id = wrapper.getAttribute('data-video-id');
            // Ajout de classes CSS pour forcer la taille
            wrapper.innerHTML = `
                <iframe 
                    class="active-video"
                    src="https://www.youtube.com/embed/${id}?autoplay=1" 
                    frameborder="0" 
                    allow="autoplay; encrypted-media" 
                    allowfullscreen>
                </iframe>
            `;
        });
    });
</script>

<style lang="scss">
    @use "../styles/variables" as *;

    .portfolio-section { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem 5rem; }

    .filter-container {
        display: flex; justify-content: center; gap: 1rem; margin-bottom: 4rem; flex-wrap: wrap;
    }

    .filter-btn {
        background: transparent; border: 1px solid rgba(255,255,255,0.1);
        color: white; padding: 0.6rem 1.5rem; border-radius: 30px; cursor: pointer;
        transition: all 0.3s ease; text-transform: uppercase;
        &:hover, &.active { background: $gold; color: $dark-blue; border-color: $gold; }
    }

    .video-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 3rem 2rem;
    }

    .thumbnail-wrapper {
        position: relative;
        padding-bottom: 56.25%; // Ratio 16:9
        height: 0;
        background: #000;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;

        img {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            object-fit: cover;
        }

        // CRUCIAL : L'iframe doit remplir le conteneur 16:9
        iframe.active-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .play-overlay {
            position: absolute; inset: 0; background: rgba(0,0,0,0.4);
            display: flex; align-items: center; justify-content: center;
            opacity: 1; transition: opacity 0.3s ease;
            .play-text { border: 1px solid white; padding: 0.8rem 1.5rem; color: white; }
        }
        &:hover img { transform: scale(1.05); transition: 0.5s; }
    }

    .video-card h3 { margin-top: 1rem; font-size: 1.1rem; color: white; }
    .category-badge {
        position: absolute; top: 1rem; left: 1rem; background: rgba(0,0,0,0.7);
        color: $gold; padding: 4px 12px; font-size: 0.7rem; font-weight: bold;
    }

    @media (max-width: 768px) {
        .video-grid { grid-template-columns: 1fr; }
    }

    .thumbnail-wrapper {
        position: relative;
        padding-bottom: 56.25%; /* Ratio 16:9 */
        height: 0;
        background: #000;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;

        img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* --- LE FIX CRUCIAL ICI --- */
        /* :global() permet de cibler l'iframe injectée par le JS */
        :global(iframe) {
            position: absolute !important;
            top: 0 !important;
            left: 0 !important;
            width: 100% !important;
            height: 100% !important;
            border: none !important;
        }
    }
</style>