---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import VideoGallery from '../components/VideoGallery.astro';
---

<Layout title="Portfolio | GON VIDEO - Vidéaste à Nantes">
    <Header />
    <main class="portfolio-page">
        <header class="page-header">
            <span class="subtitle">Réalisations</span>
            <h1 class="page-title">Portfolio</h1>
            <div class="title-underline"></div>
        </header>
        
        <VideoGallery />
    </main>
    <Footer />
</Layout>

<style lang="scss">
    @use "../styles/variables" as vars;

    .portfolio-page { padding-top: 150px; background: vars.$dark-blue; }

    .page-header {
        text-align: center;
        margin-bottom: 5rem;
        .subtitle { 
            color: vars.$gold; 
            text-transform: uppercase; 
            letter-spacing: 4px; 
            font-size: 0.9rem; 
            display: block;
            margin-bottom: 1rem;
        }
        .page-title { font-size: 4rem; color: white; margin: 0; }
        .title-underline {
            width: 60px; height: 3px; background: vars.$gold; margin: 1.5rem auto 0;
        }
    }

    @media (max-width: 768px) {
        .portfolio-page { padding-top: 100px; }
        .page-header {
            margin-bottom: 3rem;
            .page-title { font-size: 2.5rem; }
        }
    }
</style>