---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Demander un devis - GON VIDEO">
    <Header />
    <main class="devis-page">
        <section class="container">
            <div class="intro">
                <h1>Votre projet commence ici</h1>
                <p>Pour vous proposer un devis précis et adapté à votre budget, j'ai besoin de quelques détails sur votre vision.</p>
            </div>

            <div class="steps">
                <div class="step">
                    <span class="number">1</span>
                    <h3>Le Brief</h3>
                    <p>On discute de vos besoins (Mariage, Clip, Entreprise).</p>
                </div>
                <div class="step">
                    <span class="number">2</span>
                    <h3>L'Analyse</h3>
                    <p>Je reviens vers vous avec une proposition tarifaire sous 48h.</p>
                </div>
                <div class="step">
                    <span class="number">3</span>
                    <h3>Le Tournage</h3>
                    <p>On fixe les dates et on donne vie à vos images.</p>
                </div>
            </div>

             
            <div class="action-box">
                <h3>Un projet Clip, Sport ou Entreprise ?</h3>
                <p>Pour toute demande hors mariage, contactez-moi directement par mail :</p>
                <a href="mailto:oliviergonnet.video@gmail.com?subject=Demande de devis personnalisé" class="btn-gold">
                    ENVOYER UN MAIL DIRECT
                </a>
            </div>

            <div class="form-container">
                <span class="badge">Spécial Mariage</span>
                <h2>Préparons ensemble votre film de mariage</h2>
                <p>Pour que je puisse comprendre l'ambiance de votre union, merci de remplir ce questionnaire détaillé :</p>
                
                <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSf-OMgKnKGz7c8TbyxwQGwyG83e3WEvZFTBcmmv4LYZu-nf5A/viewform?embedded=true" width="100%" height="5201" frameborder="0" marginheight="0" marginwidth="0">Chargement…</iframe>
            </div>

        </section>
    </main>
    <Footer />
</Layout>

<style lang="scss">
    @import "../styles/variables";

    .devis-page {
        padding: 150px 1rem 80px;
        text-align: center;
    }

    .container { max-width: 900px; margin: 0 auto; }

    h1 { font-size: 3rem; margin-bottom: 1rem; color: $gold; }

    .steps {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin: 4rem 0;
    }

    .step {
        background: rgba(255,255,255,0.03);
        padding: 2rem;
        border-radius: 15px;
        border: 1px solid rgba($gold, 0.1);

        .number {
            display: inline-block;
            width: 40px; height: 40px;
            background: $gold;
            color: #030f25;
            border-radius: 50%;
            line-height: 40px;
            font-weight: bold;
            margin-bottom: 1rem;
        }
    }

    .action-box {
        background: rgba($gold, 0.1);
        padding: 3rem;
        border-radius: 20px;
        border: 1px solid $gold;

        .btn-gold {
            display: inline-block;
            background: $gold;
            color: #030f25;
            padding: 1.2rem 2.5rem;
            border-radius: 5px;
            font-weight: 800;
            text-decoration: none;
            margin-top: 1.5rem;
        }
    }

    .badge {
        display: inline-block;
        padding: 0.4rem 1rem;
        background: rgba($gold, 0.2);
        color: $gold;
        border: 1px solid $gold;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 1rem;
        letter-spacing: 1px;
    }

    .form-container {
        margin-top: 5rem; // On espace bien de la partie mail
        // ... reste de ton style
    }
</style>